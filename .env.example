# Copy to .env and adjust before running docker compose or make run-*.
# .env is used by Docker Compose and as the base for make run-cli / make run-server.
# For local overrides (e.g. DB_PATH), copy .env.local.example to .env.local (takes priority).
# Generate a strong secret: openssl rand -hex 32
JWT_SECRET=
ADDR=:8080
DB_PATH=/data/server.db
TMDB_API_KEY=your-tmdb-read-access-token
# Set to true when behind a reverse proxy that sets X-Forwarded-For
TRUSTED_PROXY=false
